{
  "name": "lemnity-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:net": "next dev --hostname 0.0.0.0 -p 3001",
    "dev:3002": "next dev -p 3002",
    "dev:3030": "next dev -p 3030",
    "dev:clean": "rm -rf .next && next dev -p 3001",
    "dev:clean:3002": "rm -rf .next && next dev -p 3002",
    "dev:poll": "WATCHPACK_POLLING=true next dev -p 3001",
    "build": "NODE_ENV=production next build",
    "build:clean": "rm -rf .next && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:wait": "node scripts/wait-for-pg.mjs",
    "db:migrate": "prisma migrate deploy",
    "db:setup": "npm run db:up && npm run db:wait && prisma migrate deploy",
    "db:public-grants": "docker compose exec -T db psql -U lemnity -d lemnity < scripts/fix-pg-public.sql",
    "db:reset": "docker compose down -v && npm run db:setup",
    "deploy:production": "bash scripts/deploy-production.sh",
    "deploy:remote": "bash scripts/deploy-remote.sh",
    "postinstall": "patch-package",
    "builder:install": "npm ci --prefix services/lemnity-builder",
    "builder:dev": "npm run dev --prefix services/lemnity-builder",
    "builder:build": "npm run build --prefix services/lemnity-builder",
    "builder:start": "npm run start --prefix services/lemnity-builder",
    "lemnity-ai:up": "bash scripts/lemnity-ai-stack-up.sh",
    "lemnity-ai:health": "bash scripts/lemnity-ai-stack-health.sh",
    "manus:up": "npm run lemnity-ai:up",
    "manus:health": "npm run lemnity-ai:health",
    "debug:verify-session-log": "node scripts/check-debug-session-log.mjs",
    "debug:verify-session-log:apply": "REQUIRE_APPLY=1 node scripts/check-debug-session-log.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@measured/puck": "^0.20.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dockerode": "^4.0.10",
    "embla-carousel-react": "^8.5.0",
    "esbuild": "^0.25.0",
    "framer-motion": "^11.11.17",
    "html-to-docx": "^1.8.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "next": "15.5.15",
    "next-auth": "^4.24.10",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "react-icons": "^5.4.0",
    "react-router-dom": "^7.6.0",
    "recharts": "^2.13.3",
    "sonner": "^1.7.1",
    "swiper": "^11.1.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.25.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/dockerode": "^3.3.29",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.15",
    "patch-package": "^8.0.1",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
