# Настраивается только на ЛОКАЛЬНОЙ машине (Mac/PC с Cursor), НЕ на сервере.
# На сервере используйте: git pull && npm run deploy:production
#
# Скопируйте в deploy-remote.env (файл в .gitignore) и подставьте свои значения.
# LEMNITY_DEPLOY_SSH — user@host или имя Host из ~/.ssh/config (рекомендуется).
LEMNITY_DEPLOY_SSH=lemnity-prod
# Абсолютный путь к клону репозитория на сервере (там же лежит ecosystem.config.cjs).
LEMNITY_DEPLOY_PATH=/var/www/lmntai
