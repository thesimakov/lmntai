generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Корневой изолированный контейнер проекта. Любые данные проекта должны ссылаться на projectId.
model Project {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  subdomain String   @unique
  /// Редактор по умолчанию: `build` — /playground/build, `box` — /playground/box/editor
  preferredEditor String @default("build")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sandboxShare        SandboxShare?
  sandboxState        SandboxProjectState?
  manusSessionLink    ManusSessionLink?
  publishDomains      PublishDomainBinding[]
  imageAssets         ProjectImageAsset[]
  messages            ProjectMessage[]
  embeddings          ProjectEmbedding[]
  actionLogs          ProjectActionLog[]
  tokenUsageLogs      TokenUsageLog[]
  manusCharges        ManusChatCharge[]
  virtualEntries      UserVirtualEntry[]
  cmsSite             CmsSite?

  @@index([ownerId, updatedAt])
}

/// Публичный доступ к превью песочницы по ссылке /share/:sandboxId.
model SandboxShare {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sandboxId           String   @unique
  ownerId             String
  isPublic            Boolean  @default(false)
  /// Скрыть ссылку «Lemnity» в шапке /share (для FREE — после разовой оплаты).
  hideLemnityHeader   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([ownerId])
}

/// Снимок состояния проекта в песочнице (одна запись на sandboxId).
model SandboxProjectState {
  sandboxId  String   @id
  projectId  String   @unique
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title      String
  html       String   @db.Text
  /// JSON: { "index.html": "...", "puck.json": "...", ... }
  files      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ownerId, updatedAt])
  @@index([projectId, updatedAt])
}

/// Привязка хоста публикации к песочнице.
model PublishDomainBinding {
  id                 String   @id @default(cuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  host               String   @unique
  sandboxId          String
  ownerId            String
  isActive           Boolean  @default(true)
  verificationStatus String @default("PENDING")
  verificationToken  String?
  verifiedAt         DateTime?
  lastVerificationAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  owner              User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, sandboxId])
  @@index([projectId, isActive])
  @@index([sandboxId, isActive])
}

/// CMS-сайт в рамках проекта (1 сайт на 1 проект).
model CmsSite {
  id            String   @id @default(cuid())
  projectId     String   @unique
  ownerId       String
  name          String
  defaultLocale String   @default("ru")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner         User             @relation("CmsSiteOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       CmsSiteMember[]
  pages         CmsPage[]
  pageRevisions CmsPageRevision[]
  contentTypes  CmsContentType[]
  fields        CmsContentField[]
  entries       CmsEntry[]
  entryVersions CmsEntryVersion[]
  mediaAssets   CmsMediaAsset[]
  publishJobs   CmsPublishJob[]

  @@index([ownerId, updatedAt])
}

/// Участники сайта с правами (OWNER/ADMIN/EDITOR/VIEWER).
model CmsSiteMember {
  id        String   @id @default(cuid())
  siteId    String
  userId    String
  role      String   @default("EDITOR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site      CmsSite  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteId, userId])
  @@index([userId, updatedAt])
}

/// Многостраничная структура сайта.
model CmsPage {
  id                String   @id @default(cuid())
  siteId            String
  parentId          String?
  title             String
  slug              String
  path              String
  kind              String   @default("page")
  isHome            Boolean  @default(false)
  sortOrder         Int      @default(0)
  seoTitle          String?
  seoDescription    String?
  noIndex           Boolean  @default(false)
  draftRevisionId   String?  @unique
  publishedRevisionId String? @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  site              CmsSite          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  parent            CmsPage?         @relation("CmsPageTree", fields: [parentId], references: [id], onDelete: SetNull)
  children          CmsPage[]        @relation("CmsPageTree")
  revisions         CmsPageRevision[] @relation("CmsPageToRevision")
  draftRevision     CmsPageRevision? @relation("CmsPageDraftRevision", fields: [draftRevisionId], references: [id], onDelete: SetNull)
  publishedRevision CmsPageRevision? @relation("CmsPagePublishedRevision", fields: [publishedRevisionId], references: [id], onDelete: SetNull)

  @@unique([siteId, path])
  @@index([siteId, parentId, sortOrder])
  @@index([siteId, updatedAt])
  @@index([siteId, isHome])
}

/// Ревизия страницы (draft/published/scheduled).
model CmsPageRevision {
  id         String   @id @default(cuid())
  pageId      String
  siteId      String
  authorId    String
  version     Int
  status      String   @default("draft")
  label       String?
  content     Json
  createdAt   DateTime @default(now())

  page        CmsPage  @relation("CmsPageToRevision", fields: [pageId], references: [id], onDelete: Cascade)
  site        CmsSite  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  author      User     @relation("CmsPageRevisionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  draftOfPage CmsPage? @relation("CmsPageDraftRevision")
  publishedOfPage CmsPage? @relation("CmsPagePublishedRevision")

  @@unique([pageId, version])
  @@index([pageId, createdAt])
  @@index([siteId, status, createdAt])
}

/// Описание headless-типа контента (например article, faq, team_member).
model CmsContentType {
  id          String   @id @default(cuid())
  siteId      String
  ownerId     String
  apiKey      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  site        CmsSite            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  owner       User               @relation("CmsContentTypeOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  fields      CmsContentField[]
  entries     CmsEntry[]

  @@unique([siteId, apiKey])
  @@index([ownerId, updatedAt])
}

/// Поле типа контента (настройка схемы).
model CmsContentField {
  id            String   @id @default(cuid())
  siteId        String
  contentTypeId String
  key           String
  label         String
  fieldType     String
  required      Boolean  @default(false)
  sortOrder     Int      @default(0)
  config        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  site          CmsSite         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  contentType   CmsContentType  @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)

  @@unique([contentTypeId, key])
  @@index([siteId, contentTypeId, sortOrder])
}

/// Контент-элемент (entry) по типу.
model CmsEntry {
  id               String   @id @default(cuid())
  siteId           String
  contentTypeId    String
  slug             String
  status           String   @default("draft")
  draftVersionId   String?  @unique
  publishedVersionId String? @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  site             CmsSite          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  contentType      CmsContentType   @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  versions         CmsEntryVersion[] @relation("CmsEntryToVersion")
  draftVersion     CmsEntryVersion? @relation("CmsEntryDraftVersion", fields: [draftVersionId], references: [id], onDelete: SetNull)
  publishedVersion CmsEntryVersion? @relation("CmsEntryPublishedVersion", fields: [publishedVersionId], references: [id], onDelete: SetNull)

  @@unique([siteId, contentTypeId, slug])
  @@index([siteId, updatedAt])
}

/// Версия entry для workflow (draft/review/published).
model CmsEntryVersion {
  id         String   @id @default(cuid())
  entryId     String
  siteId      String
  authorId    String
  version     Int
  status      String   @default("draft")
  data        Json
  createdAt   DateTime @default(now())

  entry       CmsEntry  @relation("CmsEntryToVersion", fields: [entryId], references: [id], onDelete: Cascade)
  site        CmsSite   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  author      User      @relation("CmsEntryVersionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  draftOfEntry CmsEntry? @relation("CmsEntryDraftVersion")
  publishedOfEntry CmsEntry? @relation("CmsEntryPublishedVersion")

  @@unique([entryId, version])
  @@index([siteId, status, createdAt])
}

/// Медиа-файлы сайта (library).
model CmsMediaAsset {
  id        String   @id @default(cuid())
  siteId    String
  ownerId   String
  assetKey  String
  url       String
  mime      String
  bytes     Int
  alt       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site      CmsSite  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  owner     User     @relation("CmsMediaAssetOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([siteId, assetKey])
  @@index([siteId, createdAt])
}

/// История публикаций/релизов сайта.
model CmsPublishJob {
  id          String   @id @default(cuid())
  siteId       String
  createdById  String?
  status       String   @default("queued")
  snapshot     Json?
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())
  publishedAt  DateTime?

  site         CmsSite  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  createdBy    User?    @relation("CmsPublishJobAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([siteId, createdAt])
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  /// Bcrypt-хеш для входа email+пароль (у пользователей только OAuth — null)
  passwordHash   String?
  emailVerified  DateTime?
  name           String?
  avatar         String?
  image          String?
  company        String?
  isPartner      Boolean         @default(false)
  partnerApprovedAt DateTime?
  partnerApprovedById String?
  partnerApprovedBy User?        @relation("PartnerApprover", fields: [partnerApprovedById], references: [id], onDelete: SetNull)
  partnerApprovedUsers User[]    @relation("PartnerApprover")
  referralCode   String?         @unique
  referredById   String?
  referredBy     User?           @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals      User[]          @relation("UserReferrals")
  tokenBalance   Int             @default(0)
  tokenLimit     Int             @default(0)
  /// Последний календарный месяц (YYYY-MM, локальный TZ БД-хоста приложения),
  /// за который уже обработано помесячное начисление Pro/Team; остаток токенов переносится на следующий месяц.
  tokensCalendarMonthCredited String?
  plan           String          @default("FREE")
  /// Оплаченная подписка «Старт» (99 ₽ / мес): доступ, пока текущий момент раньше этого значения.
  starterPaidUntil DateTime?
  /// Разовая оплата снятия брендинга на публичном превью (тариф FREE / «Стандарт»).
  shareBrandingRemovalPaidAt DateTime?
  role           String          @default("USER")
  apiKey         String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  usageLogs      TokenUsageLog[]
  projects       Project[]
  referralWallet ReferralWallet?
  referralEarnings ReferralEarning[] @relation("ReferralEarningReferrer")
  referralRevenueFrom ReferralEarning[] @relation("ReferralEarningBuyer")
  referralWalletEntries ReferralWalletEntry[]
  withdrawalRequests WithdrawalRequest[] @relation("WithdrawalUser")
  reviewedWithdrawalRequests WithdrawalRequest[] @relation("WithdrawalReviewer")
  invitations    TeamInvitation[] @relation("TeamOwnerInvitations")
  teamMemberships TeamInvitation[] @relation("TeamInvitedUser")
  requestLogs    RequestLog[]
  authEvents     AuthEventLog[]
  manusSessions  ManusSessionLink[]
  manusCharges   ManusChatCharge[]
  publishDomains PublishDomainBinding[]
  sandboxProjects SandboxProjectState[]
  virtualWorkspace UserVirtualWorkspace?
  cmsSitesOwned CmsSite[] @relation("CmsSiteOwner")
  cmsSiteMemberships CmsSiteMember[]
  cmsPageRevisions CmsPageRevision[] @relation("CmsPageRevisionAuthor")
  cmsContentTypesOwned CmsContentType[] @relation("CmsContentTypeOwner")
  cmsEntryVersions CmsEntryVersion[] @relation("CmsEntryVersionAuthor")
  cmsMediaAssetsOwned CmsMediaAsset[] @relation("CmsMediaAssetOwner")
  cmsPublishJobs CmsPublishJob[] @relation("CmsPublishJobAuthor")

  /// Ключи прав для роли MANAGER: users.read, users.write, tariffs, team, settings.
  adminPermissions  Json?
  /// Кто создал менеджера (только для MANAGER / аудит).
  createdByAdminId  String?
  createdByAdmin    User?  @relation("AdminCreatedStaff", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  createdStaff      User[] @relation("AdminCreatedStaff")
  passwordResetTokens PasswordResetToken[]

  @@index([partnerApprovedById])
  @@index([referredById])
  @@index([createdByAdminId])
}

/// Виртуальная папка пользователя (quota + агрегированный объём).
model UserVirtualWorkspace {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Квота хранилища: по умолчанию 1 GiB на пользователя.
  limitBytes BigInt  @default(1073741824)
  usedBytes  BigInt  @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  entries    UserVirtualEntry[]
}

/// Виртуальные артефакты (requests/data) внутри пользовательской папки.
model UserVirtualEntry {
  id              String   @id @default(cuid())
  workspaceUserId String
  workspace       UserVirtualWorkspace @relation(fields: [workspaceUserId], references: [userId], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  virtualPath     String
  kind            String   @default("request")
  content         Json
  sizeBytes       Int
  createdAt       DateTime @default(now())

  @@index([workspaceUserId, createdAt])
  @@index([projectId, createdAt])
  @@index([kind, createdAt])
}

/// Единая конфигурация тарифов (числа и флаги) для платформы. Строка id = "default".
model PlatformPlanSettings {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

/// Каталог стартовых шаблонов сборки (Vite+React+TSX): пути → исходники, правила для агента.
model BuildTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String   @default("")
  /// Инструкции для LLM: править файлы, а не писать с нуля
  rules       String   @db.Text
  /// JSON: { "src/App.tsx": "..." }
  files       Json
  /// Стартовый текст запроса для поля ввода / сборки
  defaultUserPrompt String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Промокоды: скидка % с подписки или бонусные токены; правятся в /admin/promocodes.
model PromoCode {
  id              String    @id @default(cuid())
  /// Нормализованный код (верхний регистр, без пробелов)
  code            String    @unique
  isActive        Boolean   @default(true)
  /// DISCOUNT = процент от суммы периода; BONUS_TOKENS = цена без изменений + подарок токенов
  kind            String
  discountPercent Int?
  bonusTokens     Int?
  /// JSON: ["PRO","TEAM"] — на какие планы действует; null/пусто = оба
  appliesToPlans  Json?
  maxUses         Int?
  usedCount       Int       @default(0)
  validFrom       DateTime?
  validTo         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

/// Одноразовый токен сброса пароля (email+пароль). Хранится только хеш SHA-256 от секрета из письма.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TokenUsageLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  cost             Float?
  model            String
  createdAt        DateTime @default(now())

  @@index([projectId, createdAt])
}

/// Мост Lemnity AI: связь пользователя с идентификатором сессии upstream.
model ManusSessionLink {
  id                 String   @id @default(cuid())
  projectId          String   @unique
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  manusSessionId     String   @unique
  title              String?
  latestMessage      String?
  latestMessageAt    DateTime?
  unreadMessageCount Int      @default(0)
  status             String   @default("pending")
  isShared           Boolean  @default(false)
  /// Последний HTML-артефакт lemnity-builder (sandboxId вида artifact_…) для превью в списке проектов.
  previewArtifactId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId, updatedAt])
  @@index([projectId, updatedAt])
}

/// Учёт списаний за чат через мост Lemnity AI.
model ManusChatCharge {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  manusSessionId String
  eventId        String
  model          String
  promptTokens   Int
  completionTokens Int
  totalTokens    Int
  createdAt      DateTime @default(now())

  @@unique([manusSessionId, eventId])
  @@unique([projectId, eventId])
  @@index([projectId, createdAt])
  @@index([userId, createdAt])
}

/// Изолированное хранилище бинарных/метаданных изображений проекта.
model ProjectImageAsset {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assetKey  String
  mime      String
  bytes     Int
  source    String
  sourceUrl String?
  createdAt DateTime @default(now())

  @@unique([projectId, assetKey])
  @@index([projectId, createdAt])
}

/// Изолированный журнал сообщений проекта (LLM / действия пользователя).
model ProjectMessage {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
}

/// Изолированные записи embeddings/vector namespace для проекта.
model ProjectEmbedding {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  namespace   String
  vectorRef   String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([projectId, namespace])
}

/// Изолированный лог действий проекта (операции API/биллинга/экспорт).
model ProjectActionLog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  action    String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([action, createdAt])
}

model ReferralWallet {
  userId            String   @id
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableRubMinor Int      @default(0)
  availableTjsMinor Int      @default(0)
  availableUsdMinor Int      @default(0)
  lifetimeRubMinor  Int      @default(0)
  lifetimeTjsMinor  Int      @default(0)
  lifetimeUsdMinor  Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ReferralEarning {
  id                String   @id @default(cuid())
  referrerId        String
  referredUserId    String
  paymentEventId    String   @unique
  paymentId         String?
  planId            String?
  sourceAmountMinor Int
  sourceCurrency    String
  rewardAmountMinor Int
  rewardCurrency    String
  rateUsed          Float
  createdAt         DateTime @default(now())
  referrer          User     @relation("ReferralEarningReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser      User     @relation("ReferralEarningBuyer", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId, createdAt])
  @@index([referredUserId, createdAt])
}

model ReferralWalletEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency   String
  amountMinor Int
  kind       String
  sourceType String?
  sourceId   String?
  note       String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sourceType, sourceId])
}

model WithdrawalRequest {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("WithdrawalUser", fields: [userId], references: [id], onDelete: Cascade)
  amountMinor  Int
  currency     String
  status       String   @default("PENDING")
  details      String?  @db.Text
  createdAt    DateTime @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?    @relation("WithdrawalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote   String?  @db.Text

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([reviewedById])
}

model TeamInvitation {
  id            String   @id @default(cuid())
  userId        String
  invitedUserId String?
  email         String
  role          String   @default("EDITOR")
  status        String   @default("INVITED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation("TeamOwnerInvitations", fields: [userId], references: [id], onDelete: Cascade)
  invitedUser   User?    @relation("TeamInvitedUser", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@unique([userId, email])
  @@index([userId, status])
  @@index([invitedUserId])
}

/// Журнал HTTP-запросов к API (метаданные + усечённое тело).
model RequestLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  method       String
  pathname     String
  search       String?
  statusCode   Int
  durationMs   Int
  ip           String?
  userAgent    String?
  referer      String?
  bodyPreview  String?  @db.Text
  error        String?  @db.Text

  @@index([createdAt])
  @@index([userId, createdAt])
}

/// События входа/выхода и привязки OAuth.
model AuthEventLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  provider  String?
  email     String?
  ip        String?
  userAgent String?
  metadata  Json?

  @@index([createdAt])
  @@index([userId, createdAt])
}
