generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Публичный доступ к превью песочницы по ссылке /share/:sandboxId.
model SandboxShare {
  id                  String   @id @default(cuid())
  sandboxId           String   @unique
  ownerId             String
  isPublic            Boolean  @default(false)
  /// Скрыть ссылку «Lemnity» в шапке /share (для FREE — после разовой оплаты).
  hideLemnityHeader   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([ownerId])
}

/// Привязка хоста публикации к песочнице.
model PublishDomainBinding {
  id         String   @id @default(cuid())
  host       String   @unique
  sandboxId  String
  ownerId    String
  isActive   Boolean  @default(true)
  verificationStatus String @default("PENDING")
  verificationToken  String?
  verifiedAt         DateTime?
  lastVerificationAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId, sandboxId])
  @@index([sandboxId, isActive])
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  /// Bcrypt-хеш для входа email+пароль (у пользователей только OAuth — null)
  passwordHash   String?
  emailVerified  DateTime?
  name           String?
  avatar         String?
  image          String?
  company        String?
  isPartner      Boolean         @default(false)
  partnerApprovedAt DateTime?
  partnerApprovedById String?
  partnerApprovedBy User?        @relation("PartnerApprover", fields: [partnerApprovedById], references: [id], onDelete: SetNull)
  partnerApprovedUsers User[]    @relation("PartnerApprover")
  referralCode   String?         @unique
  referredById   String?
  referredBy     User?           @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals      User[]          @relation("UserReferrals")
  tokenBalance   Int             @default(0)
  tokenLimit     Int             @default(0)
  plan           String          @default("FREE")
  /// Разовая оплата снятия брендинга на публичном превью (тариф FREE / «Стандарт»).
  shareBrandingRemovalPaidAt DateTime?
  role           String          @default("USER")
  apiKey         String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  usageLogs      TokenUsageLog[]
  referralWallet ReferralWallet?
  referralEarnings ReferralEarning[] @relation("ReferralEarningReferrer")
  referralRevenueFrom ReferralEarning[] @relation("ReferralEarningBuyer")
  referralWalletEntries ReferralWalletEntry[]
  withdrawalRequests WithdrawalRequest[] @relation("WithdrawalUser")
  reviewedWithdrawalRequests WithdrawalRequest[] @relation("WithdrawalReviewer")
  invitations    TeamInvitation[] @relation("TeamOwnerInvitations")
  teamMemberships TeamInvitation[] @relation("TeamInvitedUser")
  requestLogs    RequestLog[]
  authEvents     AuthEventLog[]
  manusSessions  ManusSessionLink[]
  manusCharges   ManusChatCharge[]
  publishDomains PublishDomainBinding[]
  virtualWorkspace UserVirtualWorkspace?

  /// Ключи прав для роли MANAGER: users.read, users.write, tariffs, team, settings.
  adminPermissions  Json?
  /// Кто создал менеджера (только для MANAGER / аудит).
  createdByAdminId  String?
  createdByAdmin    User?  @relation("AdminCreatedStaff", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  createdStaff      User[] @relation("AdminCreatedStaff")

  @@index([partnerApprovedById])
  @@index([referredById])
  @@index([createdByAdminId])
}

/// Виртуальная папка пользователя (quota + агрегированный объём).
model UserVirtualWorkspace {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Квота хранилища: по умолчанию 1 GiB на пользователя.
  limitBytes BigInt  @default(1073741824)
  usedBytes  BigInt  @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  entries    UserVirtualEntry[]
}

/// Виртуальные артефакты (requests/data) внутри пользовательской папки.
model UserVirtualEntry {
  id              String   @id @default(cuid())
  workspaceUserId String
  workspace       UserVirtualWorkspace @relation(fields: [workspaceUserId], references: [userId], onDelete: Cascade)
  virtualPath     String
  kind            String   @default("request")
  content         Json
  sizeBytes       Int
  createdAt       DateTime @default(now())

  @@index([workspaceUserId, createdAt])
  @@index([kind, createdAt])
}

/// Единая конфигурация тарифов (числа и флаги) для платформы. Строка id = "default".
model PlatformPlanSettings {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TokenUsageLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  cost             Float?
  model            String
  createdAt        DateTime @default(now())
}

/// Мост Lemnity AI: связь пользователя с идентификатором сессии upstream.
model ManusSessionLink {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  manusSessionId     String   @unique
  title              String?
  latestMessage      String?
  latestMessageAt    DateTime?
  unreadMessageCount Int      @default(0)
  status             String   @default("pending")
  isShared           Boolean  @default(false)
  /// Последний HTML-артефакт lemnity-builder (sandboxId вида artifact_…) для превью в списке проектов.
  previewArtifactId  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId, updatedAt])
}

/// Учёт списаний за чат через мост Lemnity AI.
model ManusChatCharge {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  manusSessionId String
  eventId        String
  model          String
  promptTokens   Int
  completionTokens Int
  totalTokens    Int
  createdAt      DateTime @default(now())

  @@unique([manusSessionId, eventId])
  @@index([userId, createdAt])
}

model ReferralWallet {
  userId            String   @id
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableRubMinor Int      @default(0)
  availableTjsMinor Int      @default(0)
  availableUsdMinor Int      @default(0)
  lifetimeRubMinor  Int      @default(0)
  lifetimeTjsMinor  Int      @default(0)
  lifetimeUsdMinor  Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ReferralEarning {
  id                String   @id @default(cuid())
  referrerId        String
  referredUserId    String
  paymentEventId    String   @unique
  paymentId         String?
  planId            String?
  sourceAmountMinor Int
  sourceCurrency    String
  rewardAmountMinor Int
  rewardCurrency    String
  rateUsed          Float
  createdAt         DateTime @default(now())
  referrer          User     @relation("ReferralEarningReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser      User     @relation("ReferralEarningBuyer", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId, createdAt])
  @@index([referredUserId, createdAt])
}

model ReferralWalletEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency   String
  amountMinor Int
  kind       String
  sourceType String?
  sourceId   String?
  note       String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([sourceType, sourceId])
}

model WithdrawalRequest {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("WithdrawalUser", fields: [userId], references: [id], onDelete: Cascade)
  amountMinor  Int
  currency     String
  status       String   @default("PENDING")
  details      String?  @db.Text
  createdAt    DateTime @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  reviewedBy   User?    @relation("WithdrawalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote   String?  @db.Text

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([reviewedById])
}

model TeamInvitation {
  id            String   @id @default(cuid())
  userId        String
  invitedUserId String?
  email         String
  role          String   @default("EDITOR")
  status        String   @default("INVITED")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation("TeamOwnerInvitations", fields: [userId], references: [id], onDelete: Cascade)
  invitedUser   User?    @relation("TeamInvitedUser", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@unique([userId, email])
  @@index([userId, status])
  @@index([invitedUserId])
}

/// Журнал HTTP-запросов к API (метаданные + усечённое тело).
model RequestLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  method       String
  pathname     String
  search       String?
  statusCode   Int
  durationMs   Int
  ip           String?
  userAgent    String?
  referer      String?
  bodyPreview  String?  @db.Text
  error        String?  @db.Text

  @@index([createdAt])
  @@index([userId, createdAt])
}

/// События входа/выхода и привязки OAuth.
model AuthEventLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  provider  String?
  email     String?
  ip        String?
  userAgent String?
  metadata  Json?

  @@index([createdAt])
  @@index([userId, createdAt])
}
