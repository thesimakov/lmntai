# ============================================================
# 0. Лендинг — галерея (Unsplash API, опционально)
# ============================================================
# Без ключа карточки используют Lorem Picsum (как раньше).
# Ключ: https://unsplash.com/oauth/applications — «Access Key».
# UNSPLASH_ACCESS_KEY=

# ============================================================
# 1. Веб-скрапинг (Firecrawl)
# ============================================================
# Продакшен-рекомендация: храните рабочий env вне репозитория,
# например `/etc/lemnity/production.env`, и подгружайте его перед деплоем.
FIRECRAWL_API_KEY=your_firecrawl_api_key

# ============================================================
# 2. AI-провайдеры
# ============================================================
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# ============================================================
# 3. Песочницы
# ============================================================
SANDBOX_PROVIDER=e2b
E2B_API_KEY=your_e2b_api_key

# --- Docker sandbox Lemnity AI (опционально) ---
# См. docker/manus-sandbox/README.md
# LEMNITY_AI_SANDBOX_ENABLED=true
# LEMNITY_AI_SANDBOX_IMAGE=manus-sandbox:local
# LEMNITY_AI_SANDBOX_NAME_PREFIX=lemnity-sbx
# LEMNITY_AI_SANDBOX_WORKDIR=/home/ubuntu
# LEMNITY_AI_SANDBOX_TTL_MINUTES=60
# LEMNITY_AI_SANDBOX_HTTP_TIMEOUT_MS=120000
# LEMNITY_AI_SANDBOX_DOCKER_NETWORK=
# DOCKER_HOST=unix:///var/run/docker.sock
# LEMNITY_AI_SANDBOX_SERVICE_TIMEOUT_MINUTES=30
# NEXT_PUBLIC_SANDBOX_UPSTREAM_REPO_URL=https://example.com/your-sandbox-upstream.git
# (поддерживаются прежние MANUS_SANDBOX_* — см. lib/sandbox-manager.ts)

# ============================================================
# 4. RouterAI
# ============================================================
AI_GATEWAY_BASE_URL=https://routerai.ru/api/v1
AI_GATEWAY_API_KEY=your_routerai_master_key
# Опционально: модель для smoke-check endpoint /api/routerai/health
# AI_GATEWAY_HEALTH_MODEL=openai/gpt-4.1
# Проверка именно deepseek-v4-flash (идентификатор в API — deepseek/deepseek-v4-flash):
# AI_GATEWAY_HEALTH_MODEL=deepseek/deepseek-v4-flash
# RouterAI model-cost defaults for tariff economics (RUB / 1M tokens)
# ECON_COGS_GPT41_RUB_PER_1M=670
# ECON_COGS_GEMINI3PRO_RUB_PER_1M=536
# ECON_COGS_CLAUDE_SONNET_RUB_PER_1M=702
# ECON_COGS_KIMI_RUB_PER_1M=167

# Подпись billing webhook (HMAC SHA-256, заголовок x-lemnity-signature)
# BILLING_WEBHOOK_SECRET=change_me_super_secret

# ============================================================
# 5. Мост Lemnity AI → upstream FastAPI
# ============================================================
# LEMNITY_AI_BRIDGE_ENABLED=1
# NEXT_PUBLIC_LEMNITY_AI_BRIDGE_ENABLED=1
# URL upstream API для моста. Варианты:
# - Встроенный сервис: после `npm run builder:dev` (или PM2 `lemnity-builder`) — http://127.0.0.1:8787
# - Внешний Docker (legacy): http://127.0.0.1:8000
# LEMNITY_AI_UPSTREAM_URL=http://127.0.0.1:8787
# Опционально одинаковый секрет на Next и на builder:
# LEMNITY_AI_UPSTREAM_BEARER_TOKEN=
# LEMNITY_BUILDER_BEARER_TOKEN=<тот же>
# Порт процесса lemnity-builder (если не PM2):
# LEMNITY_BUILDER_PORT=8787
# Абсолютный путь к каталогу внешнего upstream с docker-compose (только для `npm run lemnity-ai:up`):
# LEMNITY_AI_STACK_DIR=/opt/lemnity-ai-builder
# Клиент: GET /api/lemnity-ai/bootstrap
# Совместимость: MANUS_FULL_PARITY_ENABLED, MANUS_API_BASE_URL, MANUS_API_BEARER_TOKEN, MANUS_REPO_DIR

# ============================================================
# 6. База данных и аутентификация
# ============================================================
# Локально (Docker): запустите Docker Desktop, затем один раз:
#   npm run db:setup
# (поднимает Postgres и применяет prisma migrate deploy)
# Если Prisma: «denied access ... lemnity.public» — сначала `npm run db:public-grants` (Postgres в Docker), иначе `scripts/fix-pg-public.sql` от суперпользователя, либо `npm run db:reset` (сброс volume).
# Если был «access denied» / старая база: npm run db:reset && npm run db:migrate
# Без Docker: укажите URL облачного Postgres (Neon, Supabase и т.д.)
# С Docker из этого репо — смотри docker-compose (по умолчанию хост-порт 5433). 5432 часто занят системным Postgres.
# Если Prisma жалуется на неверный пароль lemnity, а контейнер db «Healthy»: на 5433 может сидеть чужой Postgres (другой docker compose — проверь `docker ps`).
# Тогда в корне репо создай .env со строкой LMNTAI_PG_HOST_PORT=5434, перезапусти `npm run db:up`, и в DATABASE_URL укажи тот же порт (compose читает .env в корне, Next — .env.local).
# Поднять БД: npm run db:up && npm run db:wait && npx prisma migrate deploy  (или npm run db:setup)
# Если контейнер запущен, но Prisma пишет «Can't reach localhost:5433», попробуйте 127.0.0.1 вместо localhost.
# DATABASE_URL="postgresql://lemnity:lemnity@127.0.0.1:5433/lemnity?schema=public"
# DATABASE_URL="postgresql://lemnity:lemnity@localhost:5433/lemnity?schema=public"
DATABASE_URL="postgresql://lemnity:lemnity@localhost:5433/lemnity?schema=public"

# Демо-вход на /login: блок «Заполнить демо» + опциональный пароль
# Пример (локально): thesimakov@gmail.com без пароля — только этот email принимается как демо.
# DEMO_LOGIN_ENABLED=true
# DEMO_LOGIN_EMAIL=thesimakov@gmail.com
# DEMO_LOGIN_NAME=Thesimakov
# Без БД, если в env нет пароля демо: `DEMO_LOGIN_BYPASS_DB=true` (только dev).
# Если задан `DEMO_LOGIN_PASSWORD` — при совпадении в форме Prisma в dev не требуется.
# DEMO_LOGIN_BYPASS_DB=true
# Пароль для демо email при быстром входе (серверная проверка). Автоподставить в кнопку «Заполнить демо» могут
# только запросы с Host localhost/127.0.0.1; на публичном домене пароль в UI не шлётся.
# DEMO_LOGIN_PASSWORD=demo123
NEXTAUTH_SECRET=your_secret_string
# Продакшен (OAuth callback, magic link). Локально: http://localhost:3000
# Обязателен публичный https://… на проде — иначе сессия после Яндекса/ OAuth не клеится, редирект снова на /login
NEXTAUTH_URL=https://lemnity.com
NEXT_PUBLIC_SITE_URL=https://lemnity.com
# Базовая зона встроенных поддоменов публикации (slug.<base-domain>):
# NEXT_PUBLIC_PUBLISH_BASE_DOMAIN=lemnity.com
# Асинхронный хук автопровижининга TLS после VERIFIED-привязки домена.
# Пример:
# PUBLISH_DOMAIN_PROVISION_HOOK='bash /var/www/lmntai/scripts/publish-domain-provision.example.sh'
# В хук передаются:
#   LMNT_PUBLISH_HOST, LMNT_PUBLISH_PROJECT_ID, LMNT_PUBLISH_OWNER_ID, LMNT_PUBLISH_EVENT
# Для примера certbot:
# LETSENCRYPT_EMAIL=ops@example.com
# За nginx (прокси на 127.0.0.1:3000) в location / обязательно, иначе Set-Cookie привяжется к неверному host:
#   proxy_set_header Host $host;
#   proxy_set_header X-Forwarded-Proto $scheme;
#   proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
# Публичный URL API (если фронт и API разведены; иначе можно оставить пустым или = SITE)
# NEXT_PUBLIC_API_BASE_URL=https://lemnity.com

# --- OAuth: Google (https://console.cloud.google.com/apis/credentials) ---
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth: GitHub (https://github.com/settings/developers) ---
# Authorization callback URL: https://YOUR_DOMAIN/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=
# Альтернативные имена (как в доке NextAuth):
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- OAuth: ВКонтакте (https://id.vk.com/about/business/go/docs/ru/vkid/latest/vk-id/connection/create-application) ---
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# --- OAuth: Яндекс (https://oauth.yandex.ru/) — в приложении включи доступы под scope login:info и login:email
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# --- Вход по ссылке на email (nodemailer). Если не задано — кнопка «ссылка» скрыта. ---
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="Lemnity <noreply@lemnity.com>"

# --- Транзакционная почта NotiSend (https://notisend.ru/dev/email/api/) ---
# Обязательно: NOTISEND_API_KEY (Bearer), иначе письма не уходят (в логах будет предупреждение).
# Ключ: https://app.notisend.ru/mailer/automation/api/messages
# NOTISEND_API_KEY=
# Опционально свой endpoint (по умолчанию https://api.notisend.ru/v1/email):
# NOTISEND_API_BASE_URL=https://api.notisend.ru/v1/email
# Отправитель для «сырых» писем без шаблона (fallback, если нет *_TEMPLATE_ID):
# NOTISEND_FROM_EMAIL="Lemnity <noreply@lemnity.com>"
# NOTISEND_FROM_NAME=Lemnity
# ID шаблона в NotiSend: плейсхолдеры params — name, email, site_url (приветствие);
# для сброса пароля добавьте reset_link.
# Шаблон приветствия после регистрации (ID из кабинета NotiSend):
# NOTISEND_WELCOME_TEMPLATE_ID=1841098
# NOTISEND_PASSWORD_RESET_TEMPLATE_ID=
# В кабинете NotiSend можно настроить триггер по событию API; для этого приложение шлёт
# отправку по шаблону после регистрации или запроса сброса.
# NOTISEND_DEBUG=1 — логировать ответ API (диагностика).

# ============================================================
# Шаблоны сборки (строки `buildTemplate` в БД)
# ============================================================
# После изменений в `lib/build-template-presets/*` встроенные пресеты (massage, it-startup, lead-pr-sales, web-studio) уже в коде,
# но существующие строки в БД не меняются. Временно включите синхронизацию:
# LEMNITY_RESYNC_BUILTIN_BUILD_TEMPLATES=1

# ============================================================
# Админ-панель /admin (вход теми же credentials, что и обычный логин)
# ============================================================
# При совпадении email+пароля с env (и NODE_ENV=development или ADMIN_BOOTSTRAP_ENABLED=1)
# пользователю выдаётся роль ADMIN и тестовый безлимит токенов.
# В продакшене задайте роль только вручную в БД или отключите bootstrap.
# ADMIN_DEFAULT_EMAIL=simakov@lemnity.ru
# ADMIN_DEFAULT_PASSWORD=your_strong_secret
# ADMIN_BOOTSTRAP_ENABLED=0
