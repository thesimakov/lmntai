# ============================================================
# 1. Веб-скрапинг (Firecrawl)
# ============================================================
FIRECRAWL_API_KEY=your_firecrawl_api_key

# ============================================================
# 2. AI-провайдеры
# ============================================================
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# ============================================================
# 3. Песочницы
# ============================================================
SANDBOX_PROVIDER=e2b
E2B_API_KEY=your_e2b_api_key

# --- AI Manus Docker sandbox (опционально) ---
# Соберите образ из репозитория ai-manus: см. docker/manus-sandbox/README.md
# MANUS_SANDBOX_ENABLED=true
# MANUS_SANDBOX_IMAGE=manus-sandbox:local
# MANUS_SANDBOX_NAME_PREFIX=lemnity-sbx
# Рабочая директория внутри контейнера (как в промптах ai-manus: /home/ubuntu)
# MANUS_SANDBOX_WORKDIR=/home/ubuntu
# TTL записи реестра на стороне Next (минуты); по истечении контейнер удаляется
# MANUS_SANDBOX_TTL_MINUTES=60
# Таймаут HTTP к FastAPI внутри контейнера (мс)
# MANUS_SANDBOX_HTTP_TIMEOUT_MS=120000
# Имя docker-сети, если контейнеры не в default bridge
# MANUS_SANDBOX_DOCKER_NETWORK=
# Сокет Docker (по умолчанию — локальный сокет демона)
# DOCKER_HOST=unix:///var/run/docker.sock
# Таймаут сервисов внутри контейнера (минуты), передаётся как SERVICE_TIMEOUT_MINUTES
# MANUS_SANDBOX_SERVICE_TIMEOUT_MINUTES=30
# URL для кнопки GitHub в студии (репо песочницы; по умолчанию — Simpleyyt/ai-manus)
# NEXT_PUBLIC_SANDBOX_UPSTREAM_REPO_URL=https://github.com/Simpleyyt/ai-manus

# ============================================================
# 4. RouterAI
# ============================================================
AI_GATEWAY_BASE_URL=https://routerai.ru/api/v1
AI_GATEWAY_API_KEY=your_routerai_master_key
# RouterAI model-cost defaults for tariff economics (RUB / 1M tokens)
# ECON_COGS_GPT41_RUB_PER_1M=670
# ECON_COGS_GEMINI3PRO_RUB_PER_1M=536
# ECON_COGS_CLAUDE_SONNET_RUB_PER_1M=702
# ECON_COGS_KIMI_RUB_PER_1M=167

# Подпись billing webhook (HMAC SHA-256, заголовок x-lemnity-signature)
# BILLING_WEBHOOK_SECRET=change_me_super_secret

# ============================================================
# 5. База данных и аутентификация
# ============================================================
# Локально (Docker): запустите Docker Desktop, затем один раз:
#   npm run db:setup
# (поднимает Postgres и применяет prisma migrate deploy)
# Если был «access denied» / старая база: npm run db:reset && npm run db:migrate
# Без Docker: укажите URL облачного Postgres (Neon, Supabase и т.д.)
# DATABASE_URL="postgresql://lemnity:lemnity@localhost:5432/lemnity?schema=public"
DATABASE_URL="postgresql://lemnity:lemnity@localhost:5432/lemnity?schema=public"

# Демо-вход на /login: блок «Заполнить демо» + опциональный пароль
# Пример (локально): thesimakov@gmail.com без пароля — только этот email принимается как демо.
# DEMO_LOGIN_ENABLED=true
# DEMO_LOGIN_EMAIL=thesimakov@gmail.com
# DEMO_LOGIN_NAME=Thesimakov
# Только NODE_ENV=development: войти без PostgreSQL (профиль/API в БД недоступны, UI — да)
# DEMO_LOGIN_BYPASS_DB=true
# Если задан — для этого email обязателен пароль при быстром входе:
# DEMO_LOGIN_PASSWORD=demo123
NEXTAUTH_SECRET=your_secret_string
# Продакшен (OAuth callback, magic link). Локально: http://localhost:3000
# Обязателен публичный https://… на проде — иначе сессия после Яндекса/ OAuth не клеится, редирект снова на /login
NEXTAUTH_URL=https://lemnity.com
NEXT_PUBLIC_SITE_URL=https://lemnity.com
# За nginx (прокси на 127.0.0.1:3000) в location / обязательно, иначе Set-Cookie привяжется к неверному host:
#   proxy_set_header Host $host;
#   proxy_set_header X-Forwarded-Proto $scheme;
#   proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
# Публичный URL API (если фронт и API разведены; иначе можно оставить пустым или = SITE)
# NEXT_PUBLIC_API_BASE_URL=https://lemnity.com

# --- OAuth: Google (https://console.cloud.google.com/apis/credentials) ---
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth: GitHub (https://github.com/settings/developers) ---
# Authorization callback URL: https://YOUR_DOMAIN/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=
# Альтернативные имена (как в доке NextAuth):
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- OAuth: ВКонтакте (https://id.vk.com/about/business/go/docs/ru/vkid/latest/vk-id/connection/create-application) ---
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# --- OAuth: Яндекс (https://oauth.yandex.ru/) — в приложении включи доступы под scope login:info и login:email
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# --- Вход по ссылке на email (nodemailer). Если не задано — кнопка «ссылка» скрыта. ---
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM="Lemnity <noreply@lemnity.com>"
